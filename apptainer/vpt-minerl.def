Bootstrap: docker
From: eclipse-temurin:8-jdk-jammy
Stage: java8

Bootstrap: docker
From: ghcr.io/astral-sh/uv:python3.12-trixie-slim
Stage: final

%files from java8
    /opt/java/openjdk /opt/java/openjdk

%files
    . /app

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    export VIRTUALGL_VERSION=3.1.4
    export VIRTUALGL_SHA256=02edc6b599571c385389af1a006f07a70c298e1d97c580a9bfd4b39d835c51e6
    apt-get update
    apt-get install -y --no-install-recommends \
        bash \
        build-essential \
        bzip2 \
        ca-certificates \
        curl \
        git \
        gzip \
        libasound2t64 \
        libcurl4t64 \
        libegl1 \
        libgl1 \
        libgl1-mesa-dri \
        libglu1-mesa \
        libglib2.0-0t64 \
        libglx-mesa0 \
        libnss3 \
        libsm6 \
        libuuid1 \
        libx11-6 \
        libxcursor1 \
        libxdamage1 \
        libxext6 \
        libxfixes3 \
        libxi6 \
        libxinerama1 \
        libxrandr2 \
        libxrender1 \
        libxss1 \
        libxt6 \
        libxtst6 \
        libxxf86vm1 \
        mesa-utils \
        patch \
        procps \
        tar \
        unzip \
        xauth \
        x11-utils \
        x11-xserver-utils \
        xvfb \
        xz-utils \
        zip \
        zstd
    curl -fsSL -o /tmp/virtualgl.deb "https://github.com/VirtualGL/virtualgl/releases/download/${VIRTUALGL_VERSION}/virtualgl_${VIRTUALGL_VERSION}_amd64.deb"
    echo "${VIRTUALGL_SHA256}  /tmp/virtualgl.deb" | sha256sum -c -
    apt-get install -y --no-install-recommends /tmp/virtualgl.deb
    rm -f /tmp/virtualgl.deb
    rm -rf /var/lib/apt/lists/*
    chmod 755 /app/docker/vpt-minerl-entrypoint.sh
    mkdir -p /outputs /tmp/minerl /tmp/gradle
    chmod 1777 /outputs /tmp/minerl /tmp/gradle
    cd /app
    export GRADLE_USER_HOME=/tmp/gradle
    export JAVA_HOME=/opt/java/openjdk
    export PATH="/app/.venv/bin:/opt/java/openjdk/bin:$PATH"
    export UV_COMPILE_BYTECODE=1
    export UV_LINK_MODE=copy
    export UV_NO_DEV=1
    export UV_PYTHON_DOWNLOADS=0
    MINERL_BUILD_MCP=1 uv sync --locked --no-editable

%environment
    export GRADLE_USER_HOME=/tmp/gradle
    export JAVA_HOME=/opt/java/openjdk
    export MALMO_MINECRAFT_OUTPUT_LOGDIR=/tmp/minerl/logs
    export MINERL_STATUS_DIR=/tmp/minerl/performance
    export MINERL_TMP_INSTANCES=1
    export MINERL_WATCHERS_DIR=/tmp/minerl/watchers
    export NVIDIA_DRIVER_CAPABILITIES=all
    export NVIDIA_VISIBLE_DEVICES=all
    export PATH="/opt/VirtualGL/bin:/app/.venv/bin:/opt/java/openjdk/bin:$PATH"
    export PYTHONUNBUFFERED=1
    export VGL_DISPLAY=egl
    export VIRTUAL_ENV=/app/.venv
    export VPT_RENDER_BACKEND=auto
    export XVFB_WHD=1024x768x24

%runscript
    exec /app/docker/vpt-minerl-entrypoint.sh "$@"

%startscript
    exec /app/docker/vpt-minerl-entrypoint.sh "$@"
